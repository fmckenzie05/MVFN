# ─────────────────────────────────────────────────────────────
# TikTok Login Kit — obtain from https://developers.tiktok.com
# ─────────────────────────────────────────────────────────────

# Your TikTok app's Client Key (public — safe in frontend)
VITE_TIKTOK_CLIENT_KEY=your_client_key_here

# Registered redirect URI (must match TikTok Developer Portal)
# Dev:        http://localhost:5173/auth/callback
# Production: https://yourdomain.com/auth/callback
VITE_TIKTOK_REDIRECT_URI=http://localhost:5173/auth/callback

# ─────────────────────────────────────────────────────────────
# ⚠️  NEVER put VITE_TIKTOK_CLIENT_SECRET here.
#     Token exchange (code → access_token) must happen on your
#     backend server to keep the client_secret private.
#     Backend endpoint: POST https://open.tiktokapis.com/v2/oauth/token/
# ─────────────────────────────────────────────────────────────
